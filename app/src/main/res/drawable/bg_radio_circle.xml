<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ĐÃ CHỌN: Viền xanh + Chấm tròn xanh ở giữa -->
    <item android:state_checked="true">
        <layer-list>
            <item>
                <shape android:shape="oval">
                    <stroke
                        android:width="1.5dp"
                        android:color="#039BE5" /> <!-- light_blue_600 -->
                    <size android:width="20dp" android:height="20dp" />
                </shape>
            </item>
            <item android:top="5dp" android:bottom="5dp" android:left="5dp" android:right="5dp">
                <shape android:shape="oval">
                    <solid android:color="#039BE5" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- ĐANG NHẤN: Hiệu ứng nhẹ -->
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="#E1F5FE" />
            <stroke
                android:width="1.5dp"
                android:color="#039BE5" />
            <size android:width="20dp" android:height="20dp" />
        </shape>
    </item>

    <!-- CHƯA CHỌN: Chỉ có viền xám mảnh (như mặc định nhưng sạch hơn) -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
            <stroke
                android:width="1.5dp"
                android:color="#CCCCCC" /> <!-- Xám nhẹ mảnh -->
            <size android:width="20dp" android:height="20dp" />
        </shape>
    </item>

</selector>