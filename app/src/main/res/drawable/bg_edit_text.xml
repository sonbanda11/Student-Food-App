<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Màu nền nhạt -->
    <solid android:color="#F5F5F5" /> <!-- màu xám nhạt -->

    <!-- Viền -->
    <stroke
        android:width="1dp"
        android:color="#DDDDDD" /> <!-- viền xám nhạt hơn -->

    <!-- Bo góc -->
    <corners android:radius="8dp" />

    <!-- Padding nội bộ (optional) -->
    <padding
        android:left="8dp"
        android:top="4dp"
        android:right="8dp"
        android:bottom="4dp"/>
</shape>