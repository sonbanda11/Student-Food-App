<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- LỚP 1: Nền Gradient 3 màu (Đóng vai trò là màu của VIỀN) -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:startColor="#00C2FF"
                android:centerColor="#FF00E5"
                android:endColor="#FFCC00"
                android:angle="45"
                android:type="linear" />
        </shape>
    </item>

    <!-- LỚP 2: Màu nền trắng ở giữa -->
    <!-- Giá trị top/bottom/left/right chính là độ dày của viền (ví dụ 2dp) -->
    <item
        android:top="1dp"
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
</layer-list>