<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- LỚP 1: Nền Gradient 3 màu (Đây sẽ là màu của VIỀN) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#00C2FF"
                android:centerColor="#FF00E5"
                android:endColor="#FFCC00"
                android:angle="45"
                android:type="linear" />
            <corners android:radius="50dp" />
        </shape>
    </item>

    <!-- LỚP 2: Màu nền nội dung (Ví dụ: Màu trắng) -->
    <!-- Khoảng cách (top, bottom, left, right) chính là độ dày của viền -->
    <item
        android:top="2dp"
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="50dp" />
        </shape>
    </item>
</layer-list>