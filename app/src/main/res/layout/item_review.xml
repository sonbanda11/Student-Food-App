<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:padding="12dp"
    android:background="@android:color/white">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/imgAvatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_person"
            android:background="@drawable/bg_circle"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/imgAvatar"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtName"
                android:text="Nguyễn Văn Sơn"
                android:textStyle="bold"
                android:textColor="#333"
                android:textSize="14sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <RatingBar
                    android:id="@+id/ratingBar"
                    style="?android:attr/ratingBarStyleSmall"
                    android:numStars="5"
                    android:rating="5"
                    android:isIndicator="true"
                    android:progressTint="#FFC107"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:id="@+id/txtRatingNumber"
                    android:text="5.0"
                    android:layout_marginStart="6dp"
                    android:textSize="12sp"
                    android:textColor="#FF9800"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/txtTime"
            android:layout_alignParentEnd="true"
            android:text="2 giờ trước"
            android:textSize="11sp"
            android:textColor="#999"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </RelativeLayout>

    <TextView
        android:id="@+id/txtComment"
        android:layout_marginStart="56dp"
        android:layout_marginTop="4dp"
        android:text="Đồ ăn ở đây rất ngon, đặc biệt là món bún chả. Giá cả phù hợp với sinh viên."
        android:textColor="#444"
        android:textSize="14sp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/txtTag"
        android:layout_marginStart="56dp"
        android:layout_marginTop="4dp"
        android:text="Đã chỉnh sửa"
        android:textColor="#999"
        android:textSize="11sp"
        android:textStyle="italic"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvImages"
        android:layout_marginStart="56dp"
        android:layout_marginTop="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="80dp"
        android:visibility="gone"/>

    <LinearLayout
        android:id="@+id/layoutReply"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="56dp"
        android:layout_marginTop="10dp"
        android:padding="10dp"
        android:orientation="vertical"
        android:background="#F1F1F1"
        android:visibility="gone">

        <TextView
            android:text="Phản hồi của chủ quán:"
            android:textStyle="bold"
            android:textSize="12sp"
            android:textColor="#555"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/txtOwnerReply"
            android:layout_marginTop="2dp"
            android:text="Cảm ơn bạn đã ủng hộ quán nhé!"
            android:textSize="13sp"
            android:textColor="#666"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="56dp"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:id="@+id/btnLike"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="4dp">
            <ImageView
                android:id="@+id/imgLike"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_like"
                app:tint="@color/gray_600" />
            <TextView
                android:id="@+id/txtLikeCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="0"
                android:textSize="12sp"
                android:textColor="@color/gray_600"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnDislike"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="24dp"
            android:padding="4dp">
            <ImageView
                android:id="@+id/imgDislike"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_dislike"
                app:tint="@color/gray_600"/>
            <TextView
                android:id="@+id/txtDislikeCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="0"
                android:textSize="12sp"
                android:textColor="@color/gray_600"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnComment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="24dp"
            android:padding="4dp">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_comment"
                app:tint="@color/gray_600"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Phản hồi"
                android:textSize="12sp"
                android:textColor="@color/gray_600"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>