<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="44dp"
        android:paddingBottom="12dp"
        android:paddingHorizontal="16dp"
        android:background="@android:color/white"
        android:elevation="3dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            android:padding="6dp"
            android:background="@drawable/bg_circle"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Quán yêu thích"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"/>
    </LinearLayout>

    <!-- TabLayout for 5 categories -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutFavorites"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:elevation="2dp"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabIndicatorColor="@color/purple_500"
        app:tabSelectedTextColor="@color/purple_500"
        app:tabTextColor="#666666"
        app:tabPaddingStart="8dp"
        app:tabPaddingEnd="8dp"
        app:tabPaddingTop="12dp"
        app:tabPaddingBottom="12dp"/>

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="20dp"
        android:visibility="gone"/>

    <!-- ViewPager2 for tabs -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerFavorites"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Empty state (hidden by default, shown when all tabs are empty) -->
    <TextView
        android:id="@+id/txtEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="Bạn chưa lưu quán nào\nHãy khám phá và lưu quán yêu thích!"
        android:gravity="center"
        android:textSize="15sp"
        android:textColor="#888"
        android:lineSpacingMultiplier="1.5"
        android:visibility="gone"/>

</LinearLayout>
