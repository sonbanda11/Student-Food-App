<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:clipChildren="false">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_home_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="10dp">

                <!--  -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="220dp">

                    <androidx.viewpager2.widget.ViewPager2
                        android:id="@+id/viewPagerImages"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:shapeAppearanceOverlay="@style/RoundedImageSmall"/>

                    <LinearLayout
                        android:id="@+id/layoutDots"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|center"
                        android:layout_marginBottom="8dp"
                        android:orientation="horizontal"/>

                    <TextView
                        android:id="@+id/txtTypeBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:layout_margin="10dp"
                        android:background="@drawable/bg_gradient_border"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:text="Sample"
                        android:textColor="#212121"
                        android:textSize="12sp"
                        android:textStyle="bold"/>

                </FrameLayout>

                <TextView
                    android:id="@+id/txtPlaceName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sample"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="6dp"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <!-- Rating + Distance -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical">

                    <!-- Rating -->
                    <LinearLayout
                        android:id="@+id/layoutReview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_tag"
                        android:padding="6dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_star"
                            app:tint="@color/orange_400"/>

                        <TextView
                            android:id="@+id/txtRating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginStart="4dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" | "
                            android:textSize="12sp"
                            android:layout_marginHorizontal="4dp"/>

                        <TextView
                            android:id="@+id/txtReviewCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="12sp"
                            android:textColor="@color/light_blue_800"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" Đánh giá"
                            android:textSize="12sp"
                            android:textColor="@color/light_blue_800"/>

                    </LinearLayout>

                    <!-- Distance -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_location" />

                        <TextView
                            android:id="@+id/txtDistance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0 km"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginStart="4dp"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="8dp"
                    android:layout_marginStart="5dp">

                    <TextView
                        android:id="@+id/txtStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đang mở cửa"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:layout_marginEnd="5dp"
                        android:textColor="@android:color/holo_green_dark"
                        android:layout_gravity="center_vertical" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:background="@drawable/bg_gradient_tag"
                    android:layout_marginTop="8dp">

                       <LinearLayout
                           android:id="@+id/rowAddress"
                           android:layout_width="wrap_content"
                           android:layout_height="wrap_content"
                           android:orientation="horizontal"
                           android:gravity="center_vertical">

                           <ImageView
                               android:layout_width="16dp"
                               android:layout_height="16dp"
                               android:src="@drawable/ic_location"
                               app:tint="@color/red"/>

                           <TextView
                               android:id="@+id/txtAddress"
                               android:layout_width="wrap_content"
                               android:layout_height="wrap_content"
                               android:text="Sample"
                               android:textSize="13sp"
                               android:layout_marginStart="6dp"/>

                       </LinearLayout>


                       <LinearLayout
                           android:id="@+id/rowHours"
                           android:layout_width="wrap_content"
                           android:layout_height="wrap_content"
                           android:orientation="horizontal"
                           android:layout_marginTop="6dp"
                           android:gravity="center_vertical">

                           <ImageView
                               android:layout_width="16dp"
                               android:layout_height="16dp"
                               android:src="@drawable/ic_time"
                               app:tint="@color/light_blue_600"/>

                           <TextView
                               android:id="@+id/txtOpeningHours"
                               android:layout_width="wrap_content"
                               android:layout_height="wrap_content"
                               android:text="00:00 - 00:00"
                               android:textSize="13sp"
                               android:layout_marginStart="6dp"/>

                       </LinearLayout>

                       <!-- Cuisine Section -->
                       <LinearLayout
                           android:id="@+id/layoutCuisine"
                           android:layout_width="wrap_content"
                           android:layout_height="wrap_content"
                           android:orientation="horizontal"
                           android:layout_marginTop="6dp"
                           android:gravity="center_vertical"
                           android:visibility="gone">

                           <ImageView
                               android:layout_width="16dp"
                               android:layout_height="16dp"
                               android:src="@drawable/ic_restaurant"
                               app:tint="@color/orange_400"/>

                           <TextView
                               android:id="@+id/txtCuisine"
                               android:layout_width="wrap_content"
                               android:layout_height="wrap_content"
                               android:text="Sample"
                               android:textSize="13sp"
                               android:textColor="@color/black"
                               android:layout_marginStart="6dp"/>

                       </LinearLayout>

                       <!-- Phone Section -->
                       <LinearLayout
                           android:id="@+id/layoutPhone"
                           android:layout_width="wrap_content"
                           android:layout_height="wrap_content"
                           android:orientation="horizontal"
                           android:layout_marginTop="6dp"
                           android:gravity="center_vertical"
                           android:visibility="gone">

                           <ImageView
                               android:layout_width="16dp"
                               android:layout_height="16dp"
                               android:src="@drawable/ic_phone"
                               app:tint="@color/green_600"/>

                           <TextView
                               android:id="@+id/txtOsmPhone"
                               android:layout_width="wrap_content"
                               android:layout_height="wrap_content"
                               android:text="0123 456 789"
                               android:textSize="13sp"
                               android:textColor="@color/black"
                               android:layout_marginStart="6dp"/>

                       </LinearLayout>
                       <!-- Website Section -->
                       <LinearLayout
                           android:id="@+id/layoutWebsite"
                           android:layout_width="wrap_content"
                           android:layout_height="wrap_content"
                           android:orientation="horizontal"
                           android:layout_marginTop="6dp"
                           android:gravity="center_vertical"
                           android:visibility="gone">

                           <ImageView
                               android:layout_width="16dp"
                               android:layout_height="16dp"
                               android:src="@drawable/ic_email"
                               app:tint="@color/blue_600"/>

                           <TextView
                               android:id="@+id/txtOsmWebsite"
                               android:layout_width="wrap_content"
                               android:layout_height="wrap_content"
                               android:text="www.example.com"
                               android:textSize="13sp"
                               android:textColor="@color/blue_600"
                               android:autoLink="web"
                               android:layout_marginStart="6dp"/>

                       </LinearLayout>

                       <!-- WiFi Section -->
                       <LinearLayout
                           android:id="@+id/layoutWifi"
                           android:layout_width="wrap_content"
                           android:layout_height="wrap_content"
                           android:orientation="horizontal"
                           android:layout_marginTop="6dp"
                           android:gravity="center_vertical"
                           android:visibility="gone">

                           <ImageView
                               android:layout_width="16dp"
                               android:layout_height="16dp"
                               android:src="@drawable/ic_cloud"
                               app:tint="@color/blue_600"/>

                           <TextView
                               android:id="@+id/txtWifi"
                               android:layout_width="wrap_content"
                               android:layout_height="wrap_content"
                               android:text="WiFi: Miễn phí"
                               android:textSize="13sp"
                               android:textColor="@color/black"
                               android:layout_marginStart="6dp"/>

                       </LinearLayout>

                       
                       <!-- Delivery Section -->
                       <LinearLayout
                           android:id="@+id/layoutDelivery"
                           android:layout_width="wrap_content"
                           android:layout_height="wrap_content"
                           android:orientation="horizontal"
                           android:layout_marginTop="6dp"
                           android:gravity="center_vertical"
                           android:visibility="gone">

                           <ImageView
                               android:layout_width="16dp"
                               android:layout_height="16dp"
                               android:src="@drawable/ic_direction"
                               app:tint="@color/red"/>

                           <TextView
                               android:id="@+id/txtDelivery"
                               android:layout_width="wrap_content"
                               android:layout_height="wrap_content"
                               android:text="Giao hàng: Có"
                               android:textSize="13sp"
                               android:textColor="@color/black"
                               android:layout_marginStart="6dp"/>

                       </LinearLayout>
                       
                       <!-- Capacity Section -->
                       <LinearLayout
                           android:id="@+id/layoutCapacity"
                           android:layout_width="wrap_content"
                           android:layout_height="wrap_content"
                           android:orientation="horizontal"
                           android:layout_marginTop="6dp"
                           android:gravity="center_vertical"
                           android:visibility="gone">

                           <ImageView
                               android:layout_width="16dp"
                               android:layout_height="16dp"
                               android:src="@drawable/ic_community"
                               app:tint="@color/purple_500"/>

                           <TextView
                               android:id="@+id/txtCapacity"
                               android:layout_width="wrap_content"
                               android:layout_height="wrap_content"
                               android:text="Sô chô: 50"
                               android:textSize="13sp"
                               android:textColor="@color/black"
                               android:layout_marginStart="6dp"/>

                       </LinearLayout>

                       <!-- Price Range Section -->
                       <LinearLayout
                           android:id="@+id/layoutPriceRange"
                           android:layout_width="wrap_content"
                           android:layout_height="wrap_content"
                           android:orientation="horizontal"
                           android:layout_marginTop="6dp"
                           android:gravity="center_vertical"
                           android:visibility="gone">

                           <ImageView
                               android:layout_width="16dp"
                               android:layout_height="16dp"
                               android:src="@drawable/ic_money"
                               app:tint="@color/orange_400"/>

                           <TextView
                               android:id="@+id/txtPriceRange"
                               android:layout_width="wrap_content"
                               android:layout_height="wrap_content"
                               android:text="Giá: Chưa cập nhật"
                               android:textSize="13sp"
                               android:textColor="@color/black"
                               android:layout_marginStart="6dp"/>

                       </LinearLayout>

                       <!-- Payment Section -->
                       <LinearLayout
                           android:id="@+id/layoutPayment"
                           android:layout_width="wrap_content"
                           android:layout_height="wrap_content"
                           android:orientation="horizontal"
                           android:layout_marginTop="6dp"
                           android:gravity="center_vertical"
                           android:visibility="gone">

                           <ImageView
                               android:layout_width="16dp"
                               android:layout_height="16dp"
                               android:src="@drawable/ic_money"
                               app:tint="@color/green_600"/>

                           <TextView
                               android:id="@+id/txtPayment"
                               android:layout_width="wrap_content"
                               android:layout_height="wrap_content"
                               android:text="Thanh toán: Tiền mặt"
                               android:textSize="13sp"
                               android:textColor="@color/black"
                               android:layout_marginStart="6dp"/>

                       </LinearLayout>


                </LinearLayout>

                <!-- Description Section -->
                <LinearLayout
                    android:id="@+id/layoutDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp"
                    android:padding="12dp"
                    android:background="@drawable/bg_gradient_tag"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thông tin thêm"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"/>

                    <TextView
                        android:id="@+id/txtOsmDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Mô tả chi tiết..."
                        android:textSize="13sp"
                        android:textColor="@color/black"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

            </LinearLayout>
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:layout_marginTop="15dp">

                <!-- BACK -->
                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginStart="16dp"
                    android:background="@drawable/bg_circle_overlay"
                    android:padding="6dp"
                    android:layout_gravity="start|center_vertical"
                    android:src="@drawable/ic_back"
                    android:scaleType="fitCenter"
                    app:tint="#FFFFFF" />

                <!-- TITLE -->
                <TextView
                    android:id="@+id/txtTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_gravity="center" />

                <!-- ICON RIGHT -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="16dp">

                    <ImageView
                        android:id="@+id/btnShare"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/ic_share"
                        android:background="@drawable/bg_circle_overlay"
                        android:padding="5dp"
                        app:tint="@color/white"/>

                    <ImageView
                        android:id="@+id/btnDirection"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginStart="15dp"
                        android:layout_marginEnd="15dp"
                        android:src="@drawable/ic_direction"
                        android:background="@drawable/bg_circle_overlay"
                        android:padding="6dp"
                        app:tint="@color/white" />

                    <ImageView
                        android:id="@+id/btnFavorite"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_favorite"
                        android:background="@drawable/bg_circle_overlay"
                        android:padding="5dp"
                        app:tint="@color/white" />

                </LinearLayout>

            </FrameLayout>
        </FrameLayout>

        <!-- DESCRIPTION AND MAP HORIZONTAL LAYOUT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardDescription"
                android:layout_width="0dp"
                android:layout_height="220dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/txtDescTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Giới thiệu"
                        android:textStyle="bold"
                        android:textSize="14sp"/>

                    <TextView
                        android:id="@+id/txtDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textSize="13sp"
                        android:textColor="#444"
                        android:maxLines="3"
                        android:ellipsize="end"/>

                    <TextView
                        android:id="@+id/txtSeeMore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Xem thêm"
                        android:textColor="#2196F3"
                        android:layout_marginTop="4dp"
                        android:visibility="gone"/>

                    
                    
                    <LinearLayout
                        android:id="@+id/rowPhone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp"
                        android:gravity="center_vertical"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_phone"
                            app:tint="@color/light_blue_600"/>

                        <TextView
                            android:id="@+id/txtPhone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Số điện thoại"
                            android:textSize="13sp"
                            android:textColor="#1565C0"
                            android:layout_marginStart="6dp"/>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/rowWebsite"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp"
                        android:gravity="center_vertical"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_search"
                            app:tint="@color/light_blue_600"/>

                        <TextView
                            android:id="@+id/txtWebsite"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Website"
                            android:textSize="13sp"
                            android:textColor="#1565C0"
                            android:layout_marginStart="6dp"
                            android:maxLines="1"
                            android:ellipsize="end"/>

                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerImages"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:visibility="gone"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="220dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView
                        android:text="Vị trí bản đồ"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <com.google.android.gms.maps.MapView
                        android:id="@+id/miniMapView"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:layout_marginTop="10dp"/>

                    <TextView
                        android:id="@+id/btnOpenMaps"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:text="Xem đường đi"
                        android:textColor="@color/light_blue_600"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:drawablePadding="6dp"
                        app:drawableTint="@color/light_blue_600"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="4dp"
                        android:background="?attr/selectableItemBackground" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutMenuSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp"
            android:paddingTop="12dp"
            android:paddingBottom="16dp"
            android:background="@drawable/bg_home_card">

            <TextView
                android:id="@+id/txtMenuTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:text="Menu"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/black"/>

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabLayoutMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:tabMode="scrollable"
                android:background="@color/white"
                app:tabRippleColor="@android:color/transparent"
                app:tabIndicatorColor="@color/light_blue_400"
                app:tabIndicatorHeight="3dp"
                app:tabIndicatorFullWidth="false"
                app:tabSelectedTextColor="@color/light_blue_400"
                app:tabTextColor="#757575"
                app:tabPaddingStart="12dp"
                app:tabPaddingEnd="12dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerPlaceMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:scrollbars="none"/>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
