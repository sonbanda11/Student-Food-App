<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="10dp"
    android:layout_marginVertical="4dp"

    app:cardCornerRadius="14dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground">

        <!-- IMAGE (bo góc chuẩn) -->
        <androidx.cardview.widget.CardView
            android:layout_width="70dp"
            android:layout_height="70dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/imgGroupCover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_rounded_image"
                android:src="@drawable/sample_food"/>
        </androidx.cardview.widget.CardView>

        <!-- CONTENT -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <!-- NAME -->
            <TextView
                android:id="@+id/txtGroupName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hội mê cơm tấm Hà Nội"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="#212121"
                android:maxLines="2"
                android:ellipsize="end"/>

            <!-- MEMBER -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <ImageView
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:src="@drawable/ic_person"
                    app:tint="#9E9E9E"/>

                <TextView
                    android:id="@+id/txtMemberCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.2K thành viên"
                    android:textSize="12sp"
                    android:textColor="#757575"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

            <!-- POST -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">

                <ImageView
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:src="@drawable/ic_edit"
                    app:tint="#9E9E9E"/>

                <TextView
                    android:id="@+id/txtPostCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="45 bài/tuần"
                    android:textSize="12sp"
                    android:textColor="#757575"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- BUTTON JOIN -->
        <TextView
            android:id="@+id/btnJoin"
            android:layout_width="76dp"
            android:layout_height="30dp"
            android:text="Tham gia"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:gravity="center"
            android:background="@drawable/bg_tag_category"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>